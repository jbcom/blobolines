<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Scoped to app-owned subdirs, not the whole external/cache root (avoids
         exposing all external storage via the FileProvider). -->
    <external-files-path name="my_images" path="images/" />
    <cache-path name="my_cache_images" path="images/" />
</paths>
