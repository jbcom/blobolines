# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
dist-ssr/
*.local

# Vite / cache
.vite/
.cache/

# Test output
coverage/
__screenshots__/
.vitest-attachments/

# Dev harness captured screenshots (re-derivable)
artifacts/
test-results/
playwright-report/
playwright/.cache/

# Capacitor / Android native build artifacts
android/app/build/
android/build/
android/.gradle/
android/local.properties
android/app/release/
android/app/src/main/assets/public/
ios/App/Pods/
ios/App/App/public/
*.apk
*.aab
*.keystore

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Env
.env
.env.*
!.env.example

# itch.io asset pipeline — the owned-keys cache + raw downloads are hoarded locally and
# gitignored; only curated keepers promoted to public/assets/ ship (scripts/fetch-itch-assets.mjs).
.itch-cache/
raw-assets/

# Claude runtime cache (gates.json is tracked; state/ is re-derivable task-batch cache)
.claude/state/

# Agent-state cache (re-derivable; tracked files are directive.md + decisions.ndjson)
.agent-state/digest.md
.agent-state/cursor.md
.agent-state/.indexed-sha
.agent-state/.last-stop-sha
.agent-state/.last-compaction
.agent-state/batch.json
.claude/scheduled_tasks.lock
.agent-state/.last-stop-fingerprint

# Transient commit/PR message scratch files (written so the commit-gate hook can read
# overrides from -F FILE; removed right after use, ignored so a stray never lands).
.commitmsg.tmp
.prbody.tmp
