{
  "name": "blobolines",
  "private": true,
  "version": "0.1.16",
  "type": "module",
  "description": "Launch a squishy gel blob through endless soft cloud pads — a World-of-Goo-flavored vertical-launch physics arcade game.",
  "license": "MIT",
  "author": "Jon Bogaty <jonbogaty@gmail.com>",
  "homepage": "https://jbcom.github.io/blobolines/",
  "repository": {
    "type": "git",
    "url": "https://github.com/jbcom/blobolines.git"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:pages": "GITHUB_PAGES=true tsc --noEmit && GITHUB_PAGES=true vite build",
    "build:native": "CAPACITOR=true tsc --noEmit && CAPACITOR=true vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:update": "vitest run --config vitest.browser.config.ts --update",
    "test:e2e": "playwright test",
    "verify:seed": "tsx --tsconfig tsconfig.app.json scripts/verify-seed.ts",
    "cap:sync": "pnpm build:native && cap sync",
    "cap:run:android": "pnpm cap:sync && cap run android",
    "android:debug": "pnpm cap:sync && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor-community/keep-awake": "^8.0.1",
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/screen-orientation": "^8.0.1",
    "@fontsource-variable/fredoka": "^5.2.10",
    "@fontsource-variable/nunito": "^5.2.7",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "@react-three/rapier": "^2.2.0",
    "@use-gesture/react": "^10.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "howler": "^2.2.4",
    "lucide-react": "^1.22.0",
    "maath": "^0.10.8",
    "motion": "^12.42.2",
    "n8ao": "^1.10.2",
    "postprocessing": "^6.39.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "seedrandom": "^3.0.5",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.10",
    "zod": "^4.3.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@capacitor/cli": "^8.4.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/react": "^16.3.2",
    "@types/howler": "^2.2.13",
    "@types/node": "^26.0.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "happy-dom": "^20.10.6",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.2",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@10.33.2"
}
